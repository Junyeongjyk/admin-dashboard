# SERVER
PORT=3000
NODE_ENV=development

# DATABASE (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=1234
DB_NAME=portfolio

# AUTH / JWT
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=1h

# SWAGGER
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin123

# REDIS
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# FILE STORAGE
FILE_REPOSITORY_ROOT=/mnt/c/portfolio

# CLIENT (CORS)
CLIENT_DOMAIN=http://localhost:4143

MQTT_WS_URL=ws://localhost:9001
MQTT_TOPIC=v1/realtime