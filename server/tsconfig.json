{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,
    "strictPropertyInitialization": false, 
    
    "experimentalDecorators": true, 
    "emitDecoratorMetadata": true,

    "skipLibCheck": true
  }
}